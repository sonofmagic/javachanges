# Shared release variables for the Gradle example.
#
# Gradle publishing can consume these values from CI variables or from an env file
# loaded by your own workflow glue.

JAVACHANGES_VERSION=REPLACE_WITH_PUBLISHED_VERSION

MAVEN_RELEASE_REPOSITORY_URL=https://repo.example.com/releases
MAVEN_SNAPSHOT_REPOSITORY_URL=https://repo.example.com/snapshots
MAVEN_REPOSITORY_USERNAME=replace-me
MAVEN_REPOSITORY_PASSWORD=replace-me
