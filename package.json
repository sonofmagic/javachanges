{
  "name": "javachanges",
  "private": true,
  "version": "0.0.0",
  "description": "Documentation site and Workers deployment for javachanges",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "docs:dev": "vitepress dev website",
    "docs:build": "vitepress build website",
    "docs:preview": "vitepress preview website",
    "docs:deploy:local": "pnpm run docs:build && env XDG_CONFIG_HOME=.wrangler XDG_CACHE_HOME=.wrangler XDG_STATE_HOME=.wrangler ./node_modules/.bin/wrangler dev",
    "docs:deploy": "pnpm run docs:build && pnpm exec wrangler deploy",
    "snapshot:install": "mvn -q -DskipTests -Dmaven.repo.local=.m2/repository install",
    "snapshot:preflight": "mvn -B -DskipTests -Dmaven.repo.local=.m2/repository compile exec:java -Dexec.args=\"preflight --directory . --snapshot --snapshot-build-stamp local.dev.001\"",
    "snapshot:publish:local": "./scripts/publish-local-snapshot.sh"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "mermaid": "^11.14.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.12.1",
    "wrangler": "^4.13.2"
  }
}
