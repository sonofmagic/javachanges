MAVEN_RELEASE_REPOSITORY_URL=https://repo.example.com/maven-releases/
MAVEN_SNAPSHOT_REPOSITORY_URL=https://repo.example.com/maven-snapshots/
MAVEN_RELEASE_REPOSITORY_ID=maven-releases
MAVEN_SNAPSHOT_REPOSITORY_ID=maven-snapshots

MAVEN_REPOSITORY_USERNAME=replace-me
MAVEN_REPOSITORY_PASSWORD=replace-me

# Optional explicit release credentials
# MAVEN_RELEASE_REPOSITORY_USERNAME=replace-me
# MAVEN_RELEASE_REPOSITORY_PASSWORD=replace-me

# Optional explicit snapshot credentials
# MAVEN_SNAPSHOT_REPOSITORY_USERNAME=replace-me
# MAVEN_SNAPSHOT_REPOSITORY_PASSWORD=replace-me

# Optional GitLab token for release creation
# GITLAB_RELEASE_TOKEN=replace-me

